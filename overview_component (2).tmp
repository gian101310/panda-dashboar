// ===== OVERVIEW TAB =====
// INSERT THIS BEFORE: const TABS = ['PANELS', ...] (line ~1997 in dashboard.js)
function OverviewTab({ data, trends, pdrData, upcomingNews, spikes, confidenceMap, memoryIndex, onSelectPair, isMobile, lastUpdate }) {
  const [aiReply, setAiReply] = useState(null);
  const [aiLoading, setAiLoading] = useState(false);
  const [aiError, setAiError] = useState(null);
  const [ovTrackers, setOvTrackers] = useState([]);
  const [ovClosed, setOvClosed] = useState([]);
  const aiFetched = useRef(false);
  const mono = "'Share Tech Mono',monospace", orb = "'Orbitron',sans-serif", raj = "'Rajdhani',sans-serif";

  useEffect(() => { if (aiFetched.current) return; aiFetched.current = true; fetchAI(); }, []);
  useEffect(() => {
    (async () => {
      try {
        const [oR, cR] = await Promise.all([
          fetch('/api/signal-tracker?status=OPEN').then(r => r.json()),
          fetch('/api/signal-tracker?status=CLOSED&limit=5').then(r => r.json()),
        ]);
        setOvTrackers(oR.trackers || []); setOvClosed(cR.trackers || []);
      } catch {}
    })();
  }, []);

  async function fetchAI() {
    setAiLoading(true); setAiError(null);
    try {
      const r = await fetch('/api/ai-chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ mode: 'insights' }) });
      const d = await r.json();
      if (r.ok && d.reply) setAiReply(d.reply); else setAiError(d.error || 'Failed');
    } catch { setAiError('Connection error'); }
    setAiLoading(false);
  }

  function parseAI(text) {
    if (!text) return null;
    const lines = text.split('\n').filter(l => l.trim());
    let summary = '', opportunity = '', risk = '', current = 'summary';
    for (const line of lines) {
      const lo = line.toLowerCase();
      if (lo.includes('opportunit') || lo.includes('best setup') || lo.includes('top pick') || lo.includes('strongest')) { current = 'opportunity'; continue; }
      if (lo.includes('risk') || lo.includes('avoid') || lo.includes('caution') || lo.includes('warning') || lo.includes('dead zone')) { current = 'risk'; continue; }
      const clean = line.replace(/^[\*\-\•#]+\s*/, '').replace(/\*\*/g, '');
      if (current === 'summary') summary += (summary ? ' ' : '') + clean;
      else if (current === 'opportunity') opportunity += (opportunity ? ' ' : '') + clean;
      else risk += (risk ? ' ' : '') + clean;
    }
    if (!opportunity && !risk) return { summary: text.replace(/\*\*/g, ''), opportunity: '', risk: '' };
    return { summary, opportunity, risk };
  }

  // Session
  function getOvSession() {
    const now = new Date(), h = now.getUTCHours(), m = now.getUTCMinutes(), total = h * 60 + m;
    const sessions = [
      { name: 'SYDNEY', color: '#00b4ff', open: 21 * 60, close: 6 * 60 },
      { name: 'TOKYO', color: '#ffd166', open: 23 * 60, close: 8 * 60 },
      { name: 'LONDON', color: '#cc77ff', open: 7 * 60, close: 16 * 60 },
      { name: 'NEW YORK', color: '#00ff9f', open: 12 * 60, close: 21 * 60 },
    ];
    const isOn = (s) => s.open > s.close ? (total >= s.open || total < s.close) : (total >= s.open && total < s.close);
    const active = sessions.filter(isOn);
    let countdown = null;
    if (active.length > 0) {
      let closeMin = active[0].close;
      if (active[0].open > active[0].close && total >= active[0].open) closeMin += 1440;
      let diff = closeMin - total; if (diff < 0) diff += 1440;
      countdown = { h: Math.floor(diff / 60), m: diff % 60 };
    }
    return { sessions, active, isOn, countdown };
  }

  function getOvMarketMode() {
    const valid = data.filter(r => Math.abs(r.gap ?? 0) >= 5 && !r.hard_invalid);
    const strongMom = Object.values(trends).filter(t => ['STRONG', 'BUILDING'].includes(t.momentum)).length;
    const chaotic = Object.values(trends).filter(t => ['REVERSING', 'FADING'].includes(t.momentum)).length;
    if (valid.length >= 6 && strongMom >= 4) return { mode: 'TRENDING', color: '#00ff9f', bg: 'rgba(0,255,159,0.08)' };
    if (chaotic >= 4 || (valid.length >= 5 && strongMom <= 1)) return { mode: 'CHAOTIC', color: '#ff4d6d', bg: 'rgba(255,77,109,0.08)' };
    return { mode: 'RANGING', color: '#ffd166', bg: 'rgba(255,209,102,0.08)' };
  }

  function getCurrStr() {
    const str = {}, cnt = {};
    ['USD', 'EUR', 'GBP', 'JPY', 'AUD', 'CAD', 'NZD'].forEach(c => { str[c] = 0; cnt[c] = 0; });
    data.forEach(r => {
      const b = r.symbol?.slice(0, 3), q = r.symbol?.slice(3, 6), g = r.gap ?? 0;
      if (b && str[b] !== undefined) { str[b] += g; cnt[b]++; }
      if (q && str[q] !== undefined) { str[q] -= g; cnt[q]++; }
    });
    return Object.entries(str).map(([c, v]) => {
      const avg = cnt[c] ? v / cnt[c] : 0;
      let flow = 'NEUTRAL';
      if (avg > 2) flow = 'STRONG'; else if (avg > 0.5) flow = 'RISING';
      else if (avg < -2) flow = 'WEAK'; else if (avg < -0.5) flow = 'FALLING';
      return { currency: c, strength: avg, flow };
    }).sort((a, b) => b.strength - a.strength);
  }

  function getOvExposure() {
    const exp = {};
    ['USD', 'EUR', 'GBP', 'JPY', 'AUD', 'CAD', 'NZD'].forEach(c => exp[c] = 0);
    data.filter(r => r.bias === 'BUY' || r.bias === 'SELL').forEach(r => {
      const b = r.symbol?.slice(0, 3), q = r.symbol?.slice(3, 6);
      if (r.bias === 'BUY') { exp[b] = (exp[b] || 0) + 1; exp[q] = (exp[q] || 0) - 1; }
      else { exp[b] = (exp[b] || 0) - 1; exp[q] = (exp[q] || 0) + 1; }
    });
    return Object.entries(exp).map(([c, v]) => ({ currency: c, exposure: v, abs: Math.abs(v) })).sort((a, b) => b.abs - a.abs);
  }

  function ovTier(row) {
    const cf = confidenceMap[row.symbol];
    const conf = cf?.confidence || 0;
    const edge = cf?.historical?.flag;
    const mom = trends[row.symbol]?.momentum || '';
    if (conf >= 70 && edge !== 'DEAD_ZONE' && ['STRONG', 'BUILDING', 'SPARK'].includes(mom)) return 'HIGH';
    if (conf >= 45 && edge !== 'DEAD_ZONE' && row.bias !== 'WAIT') return 'MID';
    return 'LOW';
  }

  function ovTags(row) {
    const tags = [];
    const cf = confidenceMap[row.symbol];
    const edge = cf?.historical?.flag;
    if (edge === 'PROVEN_EDGE') tags.push({ label: 'PROVEN', color: '#10B981', bg: 'rgba(16,185,129,0.12)' });
    if (edge === 'DEAD_ZONE') tags.push({ label: 'DEAD ZONE', color: '#EF4444', bg: 'rgba(239,68,68,0.12)' });
    if (upcomingNews?.affected_pairs?.includes(row.symbol)) tags.push({ label: 'NEWS', color: '#ffd166', bg: 'rgba(255,209,102,0.10)' });
    if ((cf?.confidence || 0) < 40 && row.bias !== 'WAIT') tags.push({ label: 'LOW CONF', color: '#ff8844', bg: 'rgba(255,136,68,0.10)' });
    if (cf?.conflict) tags.push({ label: 'CONFLICT', color: '#ff4d6d', bg: 'rgba(255,77,109,0.10)' });
    return tags;
  }

  const momColorsOv = { STRONG: '#00ff9f', BUILDING: '#66ffcc', SPARK: '#ffd166', EMERGING: '#66ffcc', STABLE: '#6b7fa8', CONSOLIDATING: '#5a6d8a', COOLING: '#ffaa44', FADING: '#ff7744', REVERSING: '#ff4d6d', NEUTRAL: '#3a4568' };

  // Computed
  const sess = getOvSession();
  const mktMode = getOvMarketMode();
  const currStr = getCurrStr();
  const exposure = getOvExposure();
  const aiSections = parseAI(aiReply);
  const sorted = [...data].sort((a, b) => (confidenceMap[b.symbol]?.confidence || 0) - (confidenceMap[a.symbol]?.confidence || 0));
  const highTier = sorted.filter(r => ovTier(r) === 'HIGH');
  const midTier = sorted.filter(r => ovTier(r) === 'MID');
  const lowTier = sorted.filter(r => ovTier(r) === 'LOW');
  const validPairs = data.filter(r => Math.abs(r.gap ?? 0) >= 5 && !r.hard_invalid && !isNeutralMatchup(r));
  const buyC = validPairs.filter(r => (r.gap ?? 0) >= 5).length;
  const sellC = validPairs.filter(r => (r.gap ?? 0) <= -5).length;
  const spikeC = spikes?.length || 0;
  const momBuild = Object.values(trends).filter(t => ['STRONG', 'BUILDING'].includes(t.momentum)).length;
  const closeAlertC = Object.values(trends).filter(t => t.closeAlert).length;
  const strongest = sorted[0];
  const momStates = ['STRONG', 'BUILDING', 'SPARK', 'EMERGING', 'STABLE', 'COOLING', 'FADING', 'REVERSING', 'NEUTRAL'];
  const momCounts = {};
  momStates.forEach(s => momCounts[s] = Object.values(trends).filter(t => t.momentum === s).length);

  // Signal card renderer
  const renderCard = (row, tier) => {
    const cf = confidenceMap[row.symbol];
    const conf = cf?.confidence || 0;
    const mom = trends[row.symbol]?.momentum || '';
    const bc = row.bias === 'BUY' ? '#00ff9f' : row.bias === 'SELL' ? '#ff4d6d' : 'var(--text-muted)';
    const tags = ovTags(row);
    const pdr = pdrData?.[row.symbol];
    const isHigh = tier === 'HIGH', isLow = tier === 'LOW';

    return (
      <div key={row.symbol} onClick={() => onSelectPair && onSelectPair(row)} style={{
        padding: isHigh ? '16px 18px' : isLow ? '8px 10px' : '12px 14px',
        background: 'var(--bg-card)', border: `1px solid ${isHigh ? bc + '30' : 'var(--border)'}`, borderRadius: 12,
        cursor: 'pointer', position: 'relative', overflow: 'hidden', transition: 'all 0.25s',
        opacity: isLow ? 0.5 : 1, boxShadow: isHigh ? `0 0 20px ${bc}08` : 'none'
      }}
        onMouseOver={e => { e.currentTarget.style.transform = 'translateY(-3px)'; e.currentTarget.style.boxShadow = `0 8px 24px ${bc}15`; e.currentTarget.style.opacity = '1'; }}
        onMouseOut={e => { e.currentTarget.style.transform = 'none'; e.currentTarget.style.boxShadow = isHigh ? `0 0 20px ${bc}08` : 'none'; e.currentTarget.style.opacity = isLow ? '0.5' : '1'; }}
      >
        {isHigh && <div style={{ position: 'absolute', top: 0, left: 0, right: 0, height: 2, background: `linear-gradient(90deg, transparent, ${bc}, transparent)` }} />}
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: isLow ? 2 : 6 }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: isLow ? 4 : 8 }}>
            <span style={{ fontFamily: orb, fontSize: isHigh ? 16 : isLow ? 11 : 13, fontWeight: 700, color: isLow ? 'var(--text-muted)' : 'var(--text-primary)', letterSpacing: isHigh ? 2 : 1 }}>{row.symbol}</span>
            <span style={{ fontFamily: mono, fontSize: isLow ? 8 : 10, fontWeight: 700, color: bc, background: `${bc}15`, border: `1px solid ${bc}40`, borderRadius: 4, padding: isLow ? '1px 4px' : '2px 8px', letterSpacing: 1 }}>{row.bias}</span>
          </div>
          <span style={{ fontFamily: isLow ? mono : orb, fontSize: isHigh ? 22 : isLow ? 10 : 16, fontWeight: 900, color: bc, lineHeight: 1 }}>
            {(row.gap ?? 0) > 0 ? '+' : ''}{(row.gap ?? 0).toFixed(1)}
          </span>
        </div>
        {!isLow && <div style={{ display: 'flex', alignItems: 'center', gap: 6, flexWrap: 'wrap', marginBottom: 6 }}>
          <span style={{ fontFamily: mono, fontSize: 9, padding: '2px 6px', borderRadius: 4, color: conf >= 70 ? '#00ff9f' : conf >= 50 ? '#ffd166' : 'var(--text-muted)', background: conf >= 70 ? 'rgba(0,255,159,0.1)' : conf >= 50 ? 'rgba(255,209,102,0.08)' : 'rgba(255,255,255,0.04)', border: `1px solid ${conf >= 70 ? '#00ff9f30' : conf >= 50 ? '#ffd16630' : 'var(--border)'}` }}>{conf}%</span>
          <span style={{ fontFamily: mono, fontSize: 9, color: momColorsOv[mom] || '#4a5578', padding: '2px 6px', borderRadius: 4, background: `${momColorsOv[mom] || '#4a5578'}12`, border: `1px solid ${momColorsOv[mom] || '#4a5578'}25` }}>{mom}</span>
          <span style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)', letterSpacing: 1 }}>{Math.abs(row.gap ?? 0) >= 9 && row.pl_zone !== 'BETWEEN' ? 'INTRA' : 'BB'}</span>
          {pdr?.pdr_strong && <span style={{ fontFamily: mono, fontSize: 8, color: '#00ff9f', background: 'rgba(0,255,159,0.08)', border: '1px solid rgba(0,255,159,0.2)', borderRadius: 3, padding: '1px 4px' }}>PDR ✓</span>}
        </div>}
        {tags.length > 0 && <div style={{ display: 'flex', gap: 4, flexWrap: 'wrap' }}>
          {tags.map(t => <span key={t.label} style={{ fontFamily: mono, fontSize: 7, color: t.color, background: t.bg, border: `1px solid ${t.color}30`, borderRadius: 3, padding: '1px 5px', letterSpacing: 1 }}>{t.label}</span>)}
        </div>}
      </div>
    );
  };

  return (
    <div style={{ display: 'flex', flexDirection: 'column', gap: isMobile ? 14 : 20 }}>

      {/* ROW 1 — MARKET PULSE BAR */}
      <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', gap: 16, padding: isMobile ? '10px 14px' : '12px 20px', background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 12, flexWrap: 'wrap' }}>
        <div style={{ display: 'flex', alignItems: 'center', gap: 8, flexWrap: 'wrap' }}>
          <div style={{ display: 'flex', alignItems: 'center', gap: 6 }}>
            <div style={{ width: 8, height: 8, borderRadius: '50%', background: isMarketOpen() ? '#00ff9f' : '#ff4d6d', boxShadow: `0 0 10px ${isMarketOpen() ? '#00ff9f' : '#ff4d6d'}`, animation: 'blink 2s infinite' }} />
            <span style={{ fontFamily: mono, fontSize: 10, color: isMarketOpen() ? '#00ff9f' : '#ff4d6d', letterSpacing: 2, fontWeight: 700 }}>{isMarketOpen() ? 'LIVE' : 'CLOSED'}</span>
          </div>
          {sess.sessions.map(s => {
            const on = sess.isOn(s);
            return <div key={s.name} style={{ display: 'flex', alignItems: 'center', gap: 4, padding: '4px 10px', borderRadius: 6, background: on ? s.color + '15' : 'rgba(255,255,255,0.02)', border: `1px solid ${on ? s.color + '40' : 'rgba(255,255,255,0.04)'}`, transition: 'all 0.3s' }}>
              <div style={{ width: 6, height: 6, borderRadius: '50%', background: on ? s.color : 'rgba(255,255,255,0.1)', boxShadow: on ? `0 0 6px ${s.color}` : 'none' }} />
              <span style={{ fontFamily: mono, fontSize: isMobile ? 7 : 9, fontWeight: on ? 700 : 400, color: on ? s.color : 'rgba(255,255,255,0.25)', letterSpacing: 1 }}>{s.name}</span>
            </div>;
          })}
          {sess.active.length > 1 && <span style={{ fontFamily: mono, fontSize: 8, color: '#ffd166', background: 'rgba(255,209,102,0.08)', border: '1px solid rgba(255,209,102,0.25)', borderRadius: 4, padding: '2px 6px', fontWeight: 700 }}>OVERLAP</span>}
        </div>
        <div style={{ display: 'flex', alignItems: 'center', gap: 12 }}>
          {sess.countdown && <div style={{ textAlign: 'center' }}>
            <div style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)', letterSpacing: 1 }}>NEXT CLOSE</div>
            <div style={{ fontFamily: orb, fontSize: 13, fontWeight: 700, color: '#00b4ff' }}>{sess.countdown.h}h {sess.countdown.m}m</div>
          </div>}
          <div style={{ padding: '5px 12px', borderRadius: 6, background: mktMode.bg, border: `1px solid ${mktMode.color}30` }}>
            <span style={{ fontFamily: mono, fontSize: 9, color: mktMode.color, fontWeight: 700, letterSpacing: 2 }}>{mktMode.mode}</span>
          </div>
          {upcomingNews?.events?.length > 0 && <div style={{ display: 'flex', alignItems: 'center', gap: 4, padding: '5px 10px', borderRadius: 6, background: 'rgba(255,209,102,0.08)', border: '1px solid rgba(255,209,102,0.25)' }}>
            <span style={{ fontFamily: mono, fontSize: 9, color: '#ffd166', fontWeight: 700 }}>📰 {upcomingNews.events.length} NEWS</span>
          </div>}
        </div>
      </div>

      {/* ROW 2 — STAT CARDS */}
      <div style={{ display: 'flex', gap: isMobile ? 8 : 12, flexWrap: 'wrap' }}>
        {[
          { label: 'VALID SIGNALS', value: validPairs.length, color: '#00b4ff', sub: `${buyC} BUY · ${sellC} SELL` },
          { label: 'STRONGEST', value: strongest ? Math.abs(strongest.gap ?? 0).toFixed(1) : '—', color: '#00ff9f', sub: strongest?.symbol || '—' },
          { label: 'SPIKES', value: spikeC, color: '#ffd166', sub: 'Active alerts' },
          { label: 'MOMENTUM', value: momBuild, color: '#66ffcc', sub: 'BUILDING + STRONG' },
          { label: 'CLOSE ALERTS', value: closeAlertC, color: closeAlertC > 0 ? '#ff4d6d' : 'var(--text-muted)', sub: closeAlertC > 0 ? 'Action needed' : 'All clear' },
        ].map((c, i) => (
          <div key={i} style={{ flex: '1 1 140px', padding: isMobile ? '12px 14px' : '16px 18px', background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 12, position: 'relative', overflow: 'hidden' }}>
            <div style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)', letterSpacing: 2, marginBottom: 8 }}>{c.label}</div>
            <div style={{ fontFamily: orb, fontSize: isMobile ? 22 : 28, fontWeight: 900, color: c.color, lineHeight: 1 }}>{c.value}</div>
            {c.sub && <div style={{ fontFamily: mono, fontSize: 9, color: 'var(--text-secondary)', marginTop: 4 }}>{c.sub}</div>}
          </div>
        ))}
      </div>

      {/* ROW 3 — MAIN GRID */}
      <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr' : '1fr 360px', gap: isMobile ? 14 : 20 }}>

        {/* LEFT — SIGNAL BOARD */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: 16 }}>
          {highTier.length > 0 && <div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 10 }}>
              <span style={{ fontFamily: mono, fontSize: 9, color: '#00ff9f', letterSpacing: 3, fontWeight: 700 }}>🛡 HIGH QUALITY</span>
              <span style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)' }}>{highTier.length} pairs</span>
            </div>
            <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr' : 'repeat(auto-fill, minmax(220px, 1fr))', gap: 10 }}>
              {highTier.map(r => renderCard(r, 'HIGH'))}
            </div>
          </div>}

          {midTier.length > 0 && <div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 10 }}>
              <span style={{ fontFamily: mono, fontSize: 9, color: 'var(--text-secondary)', letterSpacing: 3 }}>👁 MID QUALITY</span>
              <span style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)' }}>{midTier.length} pairs</span>
            </div>
            <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr' : 'repeat(auto-fill, minmax(200px, 1fr))', gap: 8 }}>
              {midTier.map(r => renderCard(r, 'MID'))}
            </div>
          </div>}

          {lowTier.length > 0 && <div>
            <div style={{ display: 'flex', alignItems: 'center', gap: 8, marginBottom: 8 }}>
              <span style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)', letterSpacing: 2 }}>📡 LOW QUALITY / INACTIVE</span>
              <span style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)' }}>{lowTier.length}</span>
            </div>
            <div style={{ display: 'grid', gridTemplateColumns: isMobile ? '1fr 1fr' : 'repeat(auto-fill, minmax(170px, 1fr))', gap: 6 }}>
              {lowTier.map(r => renderCard(r, 'LOW'))}
            </div>
          </div>}

          {/* Momentum Distribution */}
          <div style={{ padding: '14px 16px', background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 12 }}>
            <div style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)', letterSpacing: 2, marginBottom: 10 }}>MOMENTUM DISTRIBUTION</div>
            <div style={{ display: 'flex', height: 20, borderRadius: 4, overflow: 'hidden', gap: 1 }}>
              {momStates.filter(s => momCounts[s] > 0).map(s => (
                <div key={s} title={`${s}: ${momCounts[s]}`} style={{ flex: momCounts[s], background: momColorsOv[s] || '#4a5578', minWidth: 4, transition: 'all 0.3s', cursor: 'pointer' }}
                  onMouseOver={e => e.currentTarget.style.filter = 'brightness(1.3)'}
                  onMouseOut={e => e.currentTarget.style.filter = 'none'} />
              ))}
            </div>
            <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap', marginTop: 8 }}>
              {momStates.filter(s => momCounts[s] > 0).map(s => (
                <div key={s} style={{ display: 'flex', alignItems: 'center', gap: 3 }}>
                  <div style={{ width: 6, height: 6, borderRadius: 1, background: momColorsOv[s] }} />
                  <span style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)' }}>{s} {momCounts[s]}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        {/* RIGHT — CONTEXT PANELS */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: 12 }}>

          {/* Currency Strength */}
          <div style={{ padding: '14px 16px', background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 12 }}>
            <div style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)', letterSpacing: 2, marginBottom: 10 }}>📊 CURRENCY STRENGTH</div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
              {currStr.map(({ currency, strength, flow }) => {
                const pct = Math.min(Math.abs(strength) / 6, 1);
                const c = strength > 0 ? '#00ff9f' : strength < 0 ? '#ff4d6d' : 'var(--text-muted)';
                const flowC = { STRONG: '#00ff9f', RISING: '#66ffcc', NEUTRAL: '#6b7fa8', FALLING: '#ffaa44', WEAK: '#ff4d6d' };
                return <div key={currency} style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <span style={{ fontFamily: mono, fontSize: 10, color: 'var(--text-secondary)', width: 28, letterSpacing: 1 }}>{currency}</span>
                  <div style={{ flex: 1, height: 8, background: 'rgba(255,255,255,0.03)', borderRadius: 4, overflow: 'hidden', position: 'relative' }}>
                    {strength >= 0
                      ? <div style={{ position: 'absolute', left: '50%', width: `${pct * 50}%`, height: '100%', background: `linear-gradient(90deg, ${c}44, ${c})`, borderRadius: '0 4px 4px 0', transition: 'width 0.6s ease' }} />
                      : <div style={{ position: 'absolute', right: '50%', width: `${pct * 50}%`, height: '100%', background: `linear-gradient(270deg, ${c}44, ${c})`, borderRadius: '4px 0 0 4px', transition: 'width 0.6s ease' }} />}
                    <div style={{ position: 'absolute', left: '50%', top: 0, width: 1, height: '100%', background: 'rgba(255,255,255,0.1)' }} />
                  </div>
                  <span style={{ fontFamily: mono, fontSize: 8, color: flowC[flow] || '#6b7fa8', width: 44, textAlign: 'right', letterSpacing: 0.5 }}>{flow}</span>
                </div>;
              })}
            </div>
          </div>

          {/* News Panel */}
          {upcomingNews?.events?.length > 0 && <div style={{ padding: '14px 16px', background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 12 }}>
            <div style={{ fontFamily: mono, fontSize: 8, color: '#ffd166', letterSpacing: 2, marginBottom: 10, fontWeight: 700 }}>⚠ UPCOMING NEWS</div>
            {upcomingNews.events.slice(0, 3).map((ev, i) => {
              const mins = ev.minutes_until ?? 60;
              const urgent = mins < 30, critical = mins < 10;
              const c = critical ? '#ff4d6d' : urgent ? '#ffd166' : 'var(--text-secondary)';
              return <div key={i} style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', padding: '8px 10px', borderRadius: 6, marginBottom: 4, background: critical ? 'rgba(255,77,109,0.06)' : urgent ? 'rgba(255,209,102,0.04)' : 'rgba(255,255,255,0.02)', border: `1px solid ${critical ? '#ff4d6d30' : urgent ? '#ffd16620' : 'var(--border)'}` }}>
                <div>
                  <div style={{ fontFamily: mono, fontSize: 9, color: c, fontWeight: 700 }}>{ev.currency} — {ev.title || ev.event}</div>
                  {ev.affected_pairs && <div style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)', marginTop: 2 }}>Affects: {ev.affected_pairs.slice(0, 3).join(', ')}</div>}
                </div>
                <div style={{ fontFamily: orb, fontSize: 13, fontWeight: 700, color: c, padding: '4px 10px', borderRadius: 4, background: `${c}15`, animation: critical ? 'blink 1s infinite' : 'none' }}>{mins}m</div>
              </div>;
            })}
          </div>}

          {/* Exposure Meter */}
          <div style={{ padding: '14px 16px', background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 12 }}>
            <div style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)', letterSpacing: 2, marginBottom: 10 }}>📈 CURRENCY EXPOSURE</div>
            <div style={{ display: 'flex', flexDirection: 'column', gap: 6 }}>
              {exposure.map(({ currency, exposure: exp, abs: a }) => {
                const maxExp = 4, pct = Math.min(a / maxExp, 1);
                const c = a >= 3 ? '#ff4d6d' : a >= 2 ? '#ffd166' : '#00ff9f';
                return <div key={currency} style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                  <span style={{ fontFamily: mono, fontSize: 10, color: 'var(--text-secondary)', width: 28, letterSpacing: 1 }}>{currency}</span>
                  <div style={{ flex: 1, height: 6, background: 'rgba(255,255,255,0.04)', borderRadius: 3, overflow: 'hidden' }}>
                    <div style={{ width: `${pct * 100}%`, height: '100%', background: `linear-gradient(90deg, ${c}88, ${c})`, borderRadius: 3, transition: 'width 0.6s ease', boxShadow: a >= 3 ? `0 0 8px ${c}40` : 'none' }} />
                  </div>
                  <span style={{ fontFamily: mono, fontSize: 9, color: c, width: 20, textAlign: 'right' }}>{exp > 0 ? '+' : ''}{exp}</span>
                </div>;
              })}
            </div>
          </div>

          {/* AI Insight Panel */}
          <div style={{ padding: '16px 18px', background: 'linear-gradient(135deg, rgba(124,58,237,0.06), var(--bg-card))', border: '1px solid rgba(124,58,237,0.15)', borderRadius: 12 }}>
            <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 12 }}>
              <span style={{ fontFamily: mono, fontSize: 9, color: '#7C3AED', letterSpacing: 2, fontWeight: 700 }}>🐼 PANDA AI INSIGHT</span>
            </div>
            {aiLoading && <div style={{ padding: '20px 0', textAlign: 'center' }}>
              <div style={{ fontFamily: mono, fontSize: 10, color: '#7C3AED' }}>🐼 Analyzing market data...</div>
            </div>}
            {aiError && !aiLoading && <div style={{ fontFamily: mono, fontSize: 10, color: '#ff4d6d', padding: '8px 0' }}>⚠️ {aiError}</div>}
            {aiSections && !aiLoading && <div style={{ display: 'flex', flexDirection: 'column', gap: 10 }}>
              {aiSections.summary && <div>
                <div style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)', letterSpacing: 2, marginBottom: 3 }}>SUMMARY</div>
                <div style={{ fontFamily: raj, fontSize: 13, color: 'var(--text-secondary)', lineHeight: 1.4 }}>{aiSections.summary}</div>
              </div>}
              {aiSections.opportunity && <>
                <div style={{ height: 1, background: 'linear-gradient(90deg, transparent, rgba(124,58,237,0.2), transparent)' }} />
                <div>
                  <div style={{ fontFamily: mono, fontSize: 7, color: '#00ff9f', letterSpacing: 2, marginBottom: 3 }}>OPPORTUNITY</div>
                  <div style={{ fontFamily: raj, fontSize: 12, color: 'var(--text-secondary)', lineHeight: 1.4 }}>{aiSections.opportunity}</div>
                </div>
              </>}
              {aiSections.risk && <>
                <div style={{ height: 1, background: 'linear-gradient(90deg, transparent, rgba(124,58,237,0.2), transparent)' }} />
                <div>
                  <div style={{ fontFamily: mono, fontSize: 7, color: '#ff4d6d', letterSpacing: 2, marginBottom: 3 }}>RISK</div>
                  <div style={{ fontFamily: raj, fontSize: 12, color: 'var(--text-secondary)', lineHeight: 1.4 }}>{aiSections.risk}</div>
                </div>
              </>}
            </div>}
            <button onClick={fetchAI} disabled={aiLoading} style={{
              marginTop: 12, width: '100%', padding: '8px 0', fontFamily: mono, fontSize: 9,
              color: aiLoading ? 'var(--text-muted)' : '#7C3AED', background: aiLoading ? 'rgba(255,255,255,0.02)' : 'rgba(124,58,237,0.08)',
              border: `1px solid ${aiLoading ? 'var(--border)' : 'rgba(124,58,237,0.25)'}`,
              borderRadius: 6, cursor: aiLoading ? 'not-allowed' : 'pointer', letterSpacing: 2
            }}>{aiLoading ? '⏳ ANALYZING...' : '⟳ REFRESH INSIGHT'}</button>
          </div>
        </div>
      </div>

      {/* ROW 4 — TRACKER SUMMARY */}
      <div style={{ padding: '14px 18px', background: 'var(--bg-card)', border: '1px solid var(--border)', borderRadius: 12 }}>
        <div style={{ display: 'flex', alignItems: 'center', justifyContent: 'space-between', marginBottom: 10 }}>
          <span style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)', letterSpacing: 2 }}>🎯 SIGNAL TRACKER</span>
          <div style={{ display: 'flex', gap: 12 }}>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontFamily: orb, fontSize: 18, fontWeight: 900, color: '#00b4ff' }}>{ovTrackers.length}</div>
              <div style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)', letterSpacing: 1 }}>ACTIVE</div>
            </div>
            <div style={{ textAlign: 'center' }}>
              <div style={{ fontFamily: orb, fontSize: 18, fontWeight: 900, color: 'var(--text-secondary)' }}>
                {ovTrackers.length ? (ovTrackers.reduce((s, t) => s + (t.gap_at_open || 0), 0) / ovTrackers.length).toFixed(1) : '—'}
              </div>
              <div style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)', letterSpacing: 1 }}>AVG GAP</div>
            </div>
          </div>
        </div>
        {ovTrackers.length > 0 && <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap', marginBottom: 10 }}>
          {ovTrackers.map(t => {
            const dc = t.direction === 'BUY' ? '#00ff9f' : '#ff4d6d';
            return <div key={t.symbol} style={{ display: 'flex', alignItems: 'center', gap: 6, padding: '4px 10px', borderRadius: 6, background: `${dc}08`, border: `1px solid ${dc}20` }}>
              <span style={{ fontFamily: orb, fontSize: 10, fontWeight: 700, color: 'var(--text-primary)' }}>{t.symbol}</span>
              <span style={{ fontFamily: mono, fontSize: 8, color: dc }}>{t.direction}</span>
              <span style={{ fontFamily: mono, fontSize: 8, color: 'var(--text-muted)' }}>{t.gap_at_open}→{t.peak_gap}</span>
            </div>;
          })}
        </div>}
        {ovClosed.length > 0 && <>
          <div style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)', letterSpacing: 2, marginBottom: 6 }}>RECENTLY CLOSED</div>
          <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
            {ovClosed.slice(0, 3).map((t, i) => {
              const dur = t.closed_at && t.opened_at ? Math.round((new Date(t.closed_at) - new Date(t.opened_at)) / 3600000) : 0;
              return <div key={i} style={{ display: 'flex', alignItems: 'center', gap: 6, padding: '3px 8px', borderRadius: 4, background: 'rgba(255,255,255,0.02)', border: '1px solid var(--border)' }}>
                <span style={{ fontFamily: mono, fontSize: 9, color: 'var(--text-secondary)' }}>{t.symbol}</span>
                <span style={{ fontFamily: mono, fontSize: 7, color: '#ffaa44' }}>{t.close_reason}</span>
                <span style={{ fontFamily: mono, fontSize: 7, color: 'var(--text-muted)' }}>{dur}h</span>
              </div>;
            })}
          </div>
        </>}
      </div>
    </div>
  );
}