{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "ignoreCommand": "[ ! -f lib/accountGuardian.mjs ]",
  "crons": [
    {
      "path": "/api/cron/edge-revalidation",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/engine-stall",
      "schedule": "*/5 * * * *"
    }
  ]
}
