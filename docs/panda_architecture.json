  "strategies": {
    "BB": {
      "name": "Breakout Bias",
      "entry": "gap >= 5 (valid bias), any time, any day. TBG NOT required.",
      "concurrency": "No new entry if same pair has open BB trade. Re-entry allowed once closed.",
      "exit": "Gap drops >2 points from peak gap value."
    },
    "INTRA": {
      "name": "Intraday",
      "entry": "gap >= 9 + TBG confirmed (ABOVE=BUY, BELOW=SELL). Window: 2AM-4AM UAE only.",
      "concurrency": "Same as BB.",
      "exit": "10AM UAE hard close — no exceptions."
    }
  },

  "scoring": {
    "gap_score": {
      "formula": "BASE_score - QUOTE_score across D1/H4/H1",
      "range": "+/-18",
      "bias": {"BUY": "gap >= 5", "SELL": "gap <= -5", "WAIT": "between"},
      "execution": {"MARKET": "|gap| >= 9", "PULLBACK": "|gap| >= 5"}
    },
    "tbg_zones": {
      "ABOVE": "BUY valid",
      "BELOW": "SELL valid",
      "BETWEEN": "Always invalid"
    },
    "confidence": {
      "range": "0-100",
      "location": "Frontend only (computeConfidence in dashboard.js)",
      "factors": {
        "gap_magnitude": "~25-30 pts",
        "tbg_valid": "+20 pts",
        "box_aligned": "+20 pts",
        "cot": "+10 pts",
        "momentum": "+10 pts"
      }
    },
    "momentum_states": [
      "STRONG", "BUILDING", "SPARK", "CONSOLIDATING", "COOLING",
      "FADING", "REVERSING", "STABLE", "NEUTRAL", "EMERGING"
    ]
  },

  "data_flow": {
    "cycle": [
      "1. MT4 indicators write mt4_SYMBOL.txt + tbg_SYMBOL.txt every ~2 min",
      "2. app.py master_scheduler triggers run_gap_once every 5 min",
      "3. parse_mt4_file reads D1/H4/H1/ADV/ATR/BOX from mt4_SYMBOL.txt",
      "4. parse_tbg_file reads ST/FL/BIAS/ZONE/G1 from tbg_SYMBOL.txt",
      "5. compute_scores_all_pairs calculates GAP, BIAS, EXECUTION for all 21 pairs",
      "6. classify_momentum assigns one of 10 momentum states",
      "7. Upsert to Supabase 'dashboard' table (21 rows)",
      "8. Signal engine opens/closes BB and INTRA signals → signal_results",
      "9. Spike detection fires Telegram alerts if conditions met → spike_events",
      "10. Every 60 min: full snapshot → signal_snapshots"
    ],
    "dashboard_refresh": "Frontend polls /api/data every ~30 seconds",
    "ea_flow": [
      "1. EA reads score files written by app.py",
      "2. EA executes trades based on gap/bias/TBG",
      "3. EA posts results to /api/ea-result → ea_executions table"
    ]
  },

  "auth_system": {
    "method": "Cookie-based sessions (panda_session token)",
    "hash": "SHA-256 with static salt",
    "session_validation": "validateSession() in lib/auth.js — checks token, user active, expiry",
    "roles": ["admin", "vip", "user"],
    "device_limit": "max_devices per user (default 1)",
    "security_features": ["device fingerprinting", "IP tracking", "access logging", "account expiry", "session revocation"]
  },

